# Discord bot credentials
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_client_id
CLIENT_SECRET=optional_client_secret_for_oauth_links

# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/globy

# Bot owners/developers. Separate multiple IDs with commas.
DEV_IDS=your_discord_user_id

# Optional: guild that stores your custom emoji set.
EMOJI_GUILD_ID=your_emoji_server_id

# Optional custom emoji markup. Leave blank to use Unicode fallbacks.
EMOJI_GLOBE=
EMOJI_SHIELD=
EMOJI_SPARK=
EMOJI_WARN=
EMOJI_XP=
EMOJI_RANK=
EMOJI_LINK=
EMOJI_RECOVER=

# Runtime
PORT=3000
NODE_ENV=production
PREFIX=,
NO_PREFIX_ENABLED=true
NO_PREFIX_IDS=
EMBED_COLOR=#00E5FF
ERROR_COLOR=#FF4D6D
SUCCESS_COLOR=#35FF95

# Sync and safety tuning
WEBHOOK_NAME=Globy CV2 Sync
SYNC_QUEUE_DELAY=650ms
RECOVERY_BATCH_DELAY=1200ms
MAX_RECOVERY_LIMIT=100
XP_COOLDOWN=60s
MESSAGE_SPAM_WINDOW=8s
MESSAGE_SPAM_LIMIT=5
REPUTATION_COOLDOWN=12h

# Comma-separated words or phrases to block before syncing.
TOXIC_WORDS=

# Optional support links
SUPPORT_SERVER_URL=
WEBSITE_URL=
