# Required
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_client_id
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/globy
DEV_IDS=your_discord_user_id

# Common settings
PREFIX=,
DEFAULT_SYNC_MODE=plain
BOT_TAGLINE=A premium cross-server Discord bot for webhook chat, profiles, moderation, and recovery.
BOT_STATUS=Made by Adhi

# Theme
THEME_PRIMARY=#B829FF
THEME_SECONDARY=#35FF95
THEME_BACKGROUND=#050507

# Optional links and emoji
SUPPORT_SERVER_URL=
WEBSITE_URL=
EMOJI_GUILD_ID=

# Optional moderation words, comma-separated
TOXIC_WORDS=
